From 70f01c7806e2352d2abefac44f889c16ad05d557 Mon Sep 17 00:00:00 2001
From: Alex Van Damme <atv@google.com>
Date: Fri, 3 Apr 2026 12:48:23 -0700
Subject: [PATCH] Suppress Verilator C++ warnings

---
 dependency_support/verilator/verilator.BUILD.bazel | 10 +++++++++-
 verilator/defs.bzl                                 |  7 ++++++-
 2 files changed, 15 insertions(+), 2 deletions(-)

diff --git a/dependency_support/verilator/verilator.BUILD.bazel b/dependency_support/verilator/verilator.BUILD.bazel
index 1aa33f4..da7e603 100644
--- a/dependency_support/verilator/verilator.BUILD.bazel
+++ b/dependency_support/verilator/verilator.BUILD.bazel
@@ -370,13 +370,21 @@ cc_library(
     # TODO: Remove these once upstream fixes these warnings
     copts = [
         "-Wno-unused-const-variable",
+        "-Wno-sign-compare",
+        "-Wno-unused-variable",
+        "-Wno-unused-parameter",
+        "-Wno-unused-but-set-variable",
         "-std=c++17",
         "-ffp-contract=off",
     ],
     includes = [
-        "include",
         # include systemc header
         "systemc/include",
+        # Force -isystem for virtual includes to squelch header warnings in consumers
+        "_virtual_includes/verilator_lib",
+        "_virtual_includes/vltstd",
+        "_virtual_includes/verilatedos",
+        "_virtual_includes/svdpi",
     ],
     defines = ["VM_SC"],
     linkopts = [
diff --git a/verilator/defs.bzl b/verilator/defs.bzl
index fc8af53..2a77d50 100644
--- a/verilator/defs.bzl
+++ b/verilator/defs.bzl
@@ -47,7 +47,14 @@ def cc_compile_and_link_static_library(ctx, srcs, hdrs, deps, runfiles, includes
         actions = ctx.actions,
         feature_configuration = feature_configuration,
         cc_toolchain = cc_toolchain,
-        user_compile_flags = ctx.attr.copts,
+        user_compile_flags = ctx.attr.copts + [
+            "-Wno-sign-compare",
+            "-Wno-unused-variable",
+            "-Wno-unused-parameter",
+            "-Wno-unused-but-set-variable",
+            "-Wno-bool-operation",
+            "-Wno-tautological-compare",
+        ],
         srcs = srcs,
         includes = includes,
         defines = defines,
-- 
